# ============================================================
# CTF Analytics Platform — Environment Variables Template
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ============================================================

# --- Network / Domains ---
CTF_DOMAIN=ctf.yourdomain.com
ORCH_DOMAIN=orch.yourdomain.com
WEB_BASE_DOMAIN=yourdomain.com
PUBLIC_HTTP_BASE=http://ctf.yourdomain.com
ORCH_PUBLIC_BASE=http://orch.yourdomain.com

# --- Public Ports (for nc/SSH challenges) ---
PUBLIC_NC_HOST=yourdomain.com
PUBLIC_NC_PORT=31000
PUBLIC_SSH_HOST=yourdomain.com
PUBLIC_SSH_PORT=32222

# --- CTFd Database ---
CTFD_DB_USER=ctfd
CTFD_DB_PASS=changeme
CTFD_DB_NAME=ctfd
CTFD_SECRET_KEY=change-this-to-a-random-secret

# --- Analytics Database ---
ANALYTICS_DB_USER=analytics
ANALYTICS_DB_PASS=changeme
ANALYTICS_DB_NAME=analytics

# --- Orchestrator ---
MAX_CONCURRENT_SESSIONS=10
SESSION_TTL_MIN=60
DOCKER_NETWORK=ctf_edge

# --- AI Providers (at least one required for AI reports) ---
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# Set to 'gemini', 'openai', or leave empty for auto-fallback
AI_PROVIDER=
