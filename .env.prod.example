# =============================================================================
# CTF Analytics Platform — Production Environment Template
# =============================================================================
# Copy to .env.prod and fill in EVERY value before running start-production.sh.
# .env.prod is gitignored — never commit real credentials.
#
# Generate secrets:
#   openssl rand -hex 32   → for JWT_SECRET, CTFD_SECRET_KEY
#   openssl rand -hex 16   → for passwords
# =============================================================================

# --- Research metadata ---
ENVIRONMENT=production
IRB_STUDY_ID=set-after-irb-approval

# --- Network / Domains (Tailscale MagicDNS or raw Tailscale IP) ---
# Example: CTF_DOMAIN=100.x.y.z  or  CTF_DOMAIN=myhost.tail1234.ts.net
CTF_DOMAIN=set-tailscale-hostname-or-ip
ORCH_DOMAIN=set-tailscale-hostname-or-ip
WEB_BASE_DOMAIN=set-tailscale-hostname-or-ip
PUBLIC_HTTP_BASE=http://set-tailscale-hostname-or-ip
ORCH_PUBLIC_BASE=http://set-tailscale-hostname-or-ip

# --- Public Ports (nc/SSH challenges) ---
PUBLIC_NC_HOST=set-tailscale-hostname-or-ip
PUBLIC_NC_PORT=31000
PUBLIC_SSH_HOST=set-tailscale-hostname-or-ip
PUBLIC_SSH_PORT=32222

# --- CTFd Database ---
CTFD_DB_USER=ctfd
CTFD_DB_PASS=generate-strong-password
CTFD_DB_NAME=ctfd_prod

# --- CTFd Application ---
CTFD_SECRET_KEY=generate-random

# --- Analytics Database ---
ANALYTICS_DB_USER=analytics
ANALYTICS_DB_PASS=generate-strong-password
ANALYTICS_DB_NAME=analytics_prod

# --- JWT / API Auth ---
JWT_SECRET=generate-random

# --- Orchestrator ---
MAX_CONCURRENT_SESSIONS=60
SESSION_TTL_MIN=90
DOCKER_NETWORK=ctf_prod_edge

# --- AI Providers (at least one required for AI feedback reports) ---
GEMINI_API_KEY=set-real-key-here
OPENAI_API_KEY=set-real-key-here-or-leave-empty
OPENAI_MODEL=gpt-4o-mini
# Set to 'gemini', 'openai', or leave empty for auto-fallback
AI_PROVIDER=gemini
